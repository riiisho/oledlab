@{
    ViewData["Title"] = "Burn In";
    Layout = "_Layout";
}

<div class="burn-in-screen">
    <div class="burn-in-controls">
        <input class="grey-slider" type="range" min="0" max="255" value="128" />
    </div>
</div>

@section Scripts {
<script>
    const screen = document.querySelector('.burn-in-screen');
    const slider = document.querySelector('.grey-slider');

    function applyGrey() {
        const v = slider.value;
        screen.style.backgroundColor = `rgb(${v},${v},${v})`;
    }

    slider.addEventListener('input', applyGrey);
    applyGrey();
</script>
}
