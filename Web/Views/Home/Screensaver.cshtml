@{
    ViewData["Title"] = "Screensaver";
    Layout = "_Layout";
}

<canvas id="bh-canvas"></canvas>

@section Scripts {
<script>
const canvas = document.getElementById('bh-canvas');
const ctx = canvas.getContext('2d');

let W, H, cx, cy, BH_R;

function resize() {
    W = canvas.width = window.innerWidth;
    H = canvas.height = window.innerHeight;
    cx = W / 2;
    cy = H / 2;
    BH_R = Math.min(W, H) * 0.07;
}
window.addEventListener('resize', resize);
resize();

// Background stars
const stars = Array.from({ length: 350 }, () => ({
    x: Math.random(),
    y: Math.random(),
    r: Math.random() * 1.1 + 0.2,
    a: Math.random() * 0.55 + 0.2,
}));

// Accretion disk particles
const PARTICLE_COUNT = 900;
const particles = Array.from({ length: PARTICLE_COUNT }, () => {
    const minR = () => BH_R * 1.9;
    const maxR = () => BH_R * 8;
    const r = minR() + Math.pow(Math.random(), 1.5) * (maxR() - minR());
    return {
        angle: Math.random() * Math.PI * 2,
        r,
        // Keplerian: ω ∝ r^-1.5; scaled for visual pacing
        speed: 0.55 * Math.pow(r, -1.5) * Math.pow(BH_R, 1.5),
        size: Math.random() * 1.4 + 0.3,
        alpha: 0.55 + Math.random() * 0.45,
    };
});

function particleColor(r, angle) {
    // Normalised temperature: 1 = innermost, 0 = outermost
    const t = Math.max(0, 1 - (r - BH_R * 1.9) / (BH_R * 6));
    // Doppler brightening: approaching side (cos ≈ -1 when moving left) is boosted
    const doppler = 1 + 0.65 * (-Math.cos(angle));
    const brightness = Math.min(1, t * doppler);
    // Colour: white → yellow → orange → deep red
    const hue = 20 - brightness * 10;
    const sat = 95;
    const lig = Math.round(35 + brightness * 60);
    return `hsl(${hue},${sat}%,${lig}%)`;
}

let last = 0;

function frame(ts) {
    const dt = Math.min((ts - last) / 1000, 0.05);
    last = ts;

    // Pure black — OLED pixels fully off
    ctx.fillStyle = '#000';
    ctx.fillRect(0, 0, W, H);

    // Stars with subtle gravitational lensing displacement
    for (const s of stars) {
        const sx = s.x * W;
        const sy = s.y * H;
        const dx = sx - cx;
        const dy = sy - cy;
        const d2 = dx * dx + dy * dy;
        const d = Math.sqrt(d2);
        const lensStrength = BH_R * BH_R * 4;
        const factor = d > 0 ? 1 + lensStrength / (d2 + lensStrength * 0.5) * 0.18 : 1;
        ctx.beginPath();
        ctx.arc(cx + dx * factor, cy + dy * factor, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${s.a})`;
        ctx.fill();
    }

    // Sort particles so those at the "bottom" of the tilted disk draw last (in front)
    particles.sort((a, b) => Math.sin(a.angle) * a.r - Math.sin(b.angle) * b.r);

    for (const p of particles) {
        p.angle += p.speed * dt;

        const x = cx + Math.cos(p.angle) * p.r;
        // Perspective: disk tilted ~17° — squish vertical axis
        const y = cy + Math.sin(p.angle) * p.r * 0.28;

        // Occlusion: skip particles that fall inside the shadow sphere in 3-D
        const dx3 = x - cx;
        const dy3 = (y - cy) / 0.28;
        if (Math.sqrt(dx3 * dx3 + dy3 * dy3) < BH_R * 0.97) continue;

        ctx.globalAlpha = p.alpha;
        ctx.beginPath();
        ctx.arc(x, y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = particleColor(p.r, p.angle);
        ctx.fill();
    }
    ctx.globalAlpha = 1;

    // Black hole shadow — hard black core fading out to transparent
    const shadow = ctx.createRadialGradient(cx, cy, 0, cx, cy, BH_R * 2.1);
    shadow.addColorStop(0,    'rgba(0,0,0,1)');
    shadow.addColorStop(0.5,  'rgba(0,0,0,1)');
    shadow.addColorStop(0.72, 'rgba(0,0,0,0.88)');
    shadow.addColorStop(1,    'rgba(0,0,0,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, BH_R * 2.1, 0, Math.PI * 2);
    ctx.fillStyle = shadow;
    ctx.fill();

    // Photon ring — narrow bright halo just outside the shadow
    const ring = ctx.createRadialGradient(cx, cy, BH_R * 0.95, cx, cy, BH_R * 1.65);
    ring.addColorStop(0,    'rgba(0,0,0,0)');
    ring.addColorStop(0.38, 'rgba(255,190,90,0.38)');
    ring.addColorStop(0.62, 'rgba(255,110,25,0.22)');
    ring.addColorStop(1,    'rgba(0,0,0,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, BH_R * 1.65, 0, Math.PI * 2);
    ctx.fillStyle = ring;
    ctx.fill();

    // Outer diffuse glow (corona)
    const corona = ctx.createRadialGradient(cx, cy, BH_R * 1.5, cx, cy, BH_R * 4);
    corona.addColorStop(0,   'rgba(255,120,30,0.06)');
    corona.addColorStop(0.5, 'rgba(255,60,10,0.025)');
    corona.addColorStop(1,   'rgba(0,0,0,0)');
    ctx.beginPath();
    ctx.arc(cx, cy, BH_R * 4, 0, Math.PI * 2);
    ctx.fillStyle = corona;
    ctx.fill();

    requestAnimationFrame(frame);
}

requestAnimationFrame(frame);
</script>
}
